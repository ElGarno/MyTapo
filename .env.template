# MyTapo Energy Monitor Configuration Template
# Copy this file to .env and fill in your actual values

# Tapo Device Credentials
TAPO_USERNAME=your_tapo_email@example.com
TAPO_PASSWORD=your_tapo_password

# Device IP Addresses (update with your actual IPs)
SOLAR_IP_ADDRESS=192.168.178.xxx
WASHING_MACHINE_IP_ADDRESS=192.168.178.xxx
WASHING_DRYER_IP_ADDRESS=192.168.178.xxx

# Pushover Notification Settings
PUSHOVER_TAPO_API_TOKEN=your_pushover_api_token
PUSHOVER_USER_KEY=your_pushover_user_key
PUSHOVER_USER_GROUP_WOERIS=your_pushover_group_key

# InfluxDB Configuration
INFLUXDB_HOST=192.168.178.114
INFLUXDB_PORT=8088
INFLUXDB_BUCKET=power_consumption
INFLUXDB_EVENTS_BUCKET=appliance_events
INFLUXDB_TOKEN=your_influxdb_token

# InfluxDB Consumption Bucket (for daily aggregated data)
INFLUXDB_CONSUMPTION_BUCKET=consumption_daily

# Awtrix Display Configuration
AWTRIX_HOST=192.168.178.108
AWTRIX_PORT=80

# Report API Configuration
REPORT_API_TOKEN=
REPORT_API_PORT=8099

# Anthropic API (for n8n AI analysis workflows)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Instructions:
# 1. Copy this file: cp .env.template .env
# 2. Edit .env with your actual credentials and IP addresses
# 3. Never commit the .env file to version control