            },
            {
              "name": "start",
              "description": "Start date in ISO format (YYYY-MM-DD). Leave empty to use 'days' parameter or default to today."
            },
            {
              "name": "end",
              "description": "End date in ISO format (YYYY-MM-DD). Leave empty for current time."
            },
            {
              "name": "days",
              "description": "Number of days back from now. Alternative to start/end. E.g. '7' for last week, '30' for last month."
